# Managed by Ansible (k3s_cluster_init role). Do not edit by hand.
apiVersion: helm.cattle.io/v1
kind: HelmChart
metadata:
  name: cilium
  namespace: kube-system
spec:
  # bootstrap=true tells k3s' helm-controller to run the install Job with
  # hostNetwork=true and to tolerate a NotReady node. Without it, the Job pod
  # would be Pending forever — no CNI means no scheduling, but Cilium IS the
  # CNI: classic chicken-and-egg.
  bootstrap: true
  chart: "{{ k3s_cluster_init_cilium_chart_name }}"
  repo: "{{ k3s_cluster_init_cilium_chart_repo }}"
  version: "{{ k3s_cluster_init_cilium_chart_version }}"
  targetNamespace: "{{ k3s_cluster_init_cilium_namespace }}"
  valuesContent: |-
    kubeProxyReplacement: {{ k3s_cluster_init_cilium_kube_proxy_replacement | string | lower }}
    k8sServiceHost: "{{ k3s_cluster_init_apiserver_vip }}"
    k8sServicePort: 6443
    routingMode: "{{ k3s_cluster_init_cilium_routing_mode }}"
    tunnelProtocol: "{{ k3s_cluster_init_cilium_tunnel_protocol }}"
    bpf:
      masquerade: {{ k3s_cluster_init_cilium_bpf_masquerade | string | lower }}
    operator:
      replicas: {{ k3s_cluster_init_cilium_operator_replicas }}
    ipam:
      mode: "cluster-pool"
      operator:
        clusterPoolIPv4PodCIDRList:
          - "{{ k3s_cluster_init_cluster_cidr }}"
    hubble:
      enabled: {{ k3s_cluster_init_cilium_hubble_enabled | string | lower }}
      relay:
        enabled: {{ k3s_cluster_init_cilium_hubble_enabled | string | lower }}
      ui:
        enabled: {{ k3s_cluster_init_cilium_hubble_ui_enabled | string | lower }}
